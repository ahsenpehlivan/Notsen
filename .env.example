# TaskFlow Environment Variables
# Bu dosya, projeyi Github'dan çeken kişilerin hangi değişkenlere ihtiyaç 
# duyduğunu görebilmesi için .env.example olarak isimlendirilmiştir.
# Gerçek değerlerinizi .env.local dosyasına girin ve onu asla Git'e yüklemeyin.

NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
